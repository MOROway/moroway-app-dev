{
    "name": "moroway-app",
    "license": "GPL-3.0-only",
    "version": "10.3.13",
    "description": "Play with the MORO model railroad…",
    "author": "Jonathan Herrmann-Engel",
    "desktopName": "de.moroway.snap",
    "build": {
        "appId": "moroway-app",
        "productName": "MOROway App",
        "files": [
            "www"
        ],
        "linux": {
            "icon": "icon.png",
            "category": "Game",
            "target": [
                {
                    "target": "snap",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "snapcraft": {
            "base": "core24",
            "core24": {
                "useMultipass": true,
                "plugs": [
                    "default",
                    "screen-inhibit-control"
                ],
                "executableArgs": [
                    "--disable-dev-shm-usage"
                ]
            }
        }
    },
    "scripts": {
        "dist": "./scripts/insert_html.sh && electron-builder && ./scripts/cleanup_html.sh"
    },
    "devDependencies": {
        "electron": "^42.0.0",
        "electron-builder": "27.0.0-alpha.5"
    },
    "main": "www/app.js"
}